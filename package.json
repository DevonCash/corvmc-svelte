{
	"name": "corvmc-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"test:report": "vitest run --reporter=verbose --reporter=json --outputFile=test-results.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"stripe:sync-webhooks": "tsx scripts/sync-webhooks.ts",
		"db:seed": "tsx scripts/seed-dev.ts",
		"db:reset": "drizzle-kit push --force && pnpm db:seed"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.2.1",
		"@cloudflare/workers-types": "^4.20260516.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/sveltekit": "^10.4.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.19",
		"@visulima/vite-overlay": "^1.3.7",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"better-auth": "~1.4.22",
		"better-sqlite3": "^12.10.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"storybook": "^10.4.0",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.92.0",
		"zod": "^4.4.3",
		"zod4-mock": "^0.2.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1048.0",
		"@humanspeak/svelte-headless-table": "^6.0.6",
		"@tabler/icons-svelte": "^3.44.0",
		"@types/luxon": "^3.7.1",
		"bits-ui": "^2.18.1",
		"daisyui": "^5.5.19",
		"emittery": "^1.2.1",
		"luxon": "^3.7.2",
		"marked": "^18.0.3",
		"mjml": "^5.2.1",
		"postmark": "^4.0.7",
		"rrule": "^2.8.1",
		"stripe": "^22.1.1",
		"svelte-sonner": "^1.1.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		]
	}
}
