{
	"name": "corvmc-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"dev": "vite dev",
		"build": "tsx scripts/compile-email-layouts.ts && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && tsx scripts/compile-email-layouts.ts && lefthook install",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test:components": "vitest --run --project=client --project=storybook",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright install chromium && playwright test",
		"test:report": "vitest run --reporter=verbose --reporter=json --outputFile=test-results.json",
		"lint": "prettier --check . && eslint .",
		"lint:changed": "bash scripts/lint-changed.sh",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"ci:migrate": "node scripts/ci-migrate.mjs",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"stripe:sync-webhooks": "tsx scripts/sync-webhooks.ts",
		"db:seed": "tsx scripts/seed-dev.ts",
		"help:sync": "tsx scripts/sync-help-articles.ts",
		"docs:routes": "node scripts/docs/route-inventory.mjs --write",
		"docs:check": "node scripts/docs/check-docs-drift.mjs",
		"email:push": "postmark templates push postmark/templates --server-token $POSTMARK_SERVER_TOKEN",
		"email:pull": "postmark templates pull postmark/templates --server-token $POSTMARK_SERVER_TOKEN",
		"db:reset": "rm -rf .wrangler/state/v3/d1 && pnpm db:migrate:local && pnpm db:seed",
		"db:migrate:local": "for f in migrations/*/migration.sql; do wrangler d1 execute corvmc-db --local --file=\"$f\"; done",
		"db:sync": "bash scripts/sync-d1.sh"
	},
	"imports": {
		"#/*": "./src/*"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@cloudflare/workers-types": "^4.20260528.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/sveltekit": "^10.4.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.19",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "^4.1.7",
		"better-auth": "~1.6.11",
		"better-sqlite3": "^12.10.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "1.0.0-rc.3",
		"drizzle-orm": "1.0.0-rc.3",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.1",
		"eslint-plugin-svelte": "^3.18.0",
		"globals": "^17.6.0",
		"lefthook": "^2.1.9",
		"mdsvex": "^0.12.7",
		"mjml": "^5.3.0",
		"playwright": "^1.60.0",
		"postgres": "^3.4.9",
		"postmark-cli": "^1.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.4.1",
		"svelte": "^5.56.2",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.95.0",
		"zod": "^4.4.3",
		"zod4-mock": "^0.7.0"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"@sentry/cloudflare": "^10.56.0",
		"@sentry/sveltekit": "^10",
		"@tabler/icons-svelte": "^3.44.0",
		"@tiptap/core": "^3.25.0",
		"@tiptap/pm": "^3.25.0",
		"@tiptap/starter-kit": "^3.25.0",
		"bcrypt-ts": "^8.0.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"daisyui": "^5.5.20",
		"date-fns": "^4.3.0",
		"dompurify": "^3.4.8",
		"emittery": "^2.0.0",
		"linkedom": "^0.18.12",
		"marked": "^18.0.4",
		"postmark": "^4.0.7",
		"qrcode-svg": "^1.1.0",
		"stripe": "^22.2.0",
		"svelte-sonner": "^1.1.1",
		"svelte-turnstile": "^0.11.0",
		"twilio": "^6.0.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		],
		"overrides": {
			"cookie@<0.7.0": "0.7.2",
			"lodash@<4.18.0": "4.18.1"
		},
		"patchedDependencies": {
			"yargs@17.7.2": "patches/yargs@17.7.2.patch"
		}
	}
}
